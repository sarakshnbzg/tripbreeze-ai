# Required API keys
OPENAI_API_KEY=your-openai-api-key
SERPAPI_API_KEY=your-serpapi-api-key

# Database (Neon Postgres for long-term memory)
DATABASE_URL=postgresql://username:password@your-neon-host/database?sslmode=require
# NEON_DATABASE_URL=  # Alternative to DATABASE_URL
# Set to true in deployed environments to fail fast if checkpoint persistence is misconfigured.
REQUIRE_PERSISTENT_CHECKPOINTER=false

# Session security
# Change this before using the app outside local development.
SESSION_SECRET=tripbreeze-dev-secret-change-me

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=tripbreeze-ai
LANGCHAIN_API_KEY=your-langsmith-api-key

# SMTP email delivery (optional — see SMTP_SETUP.md)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=your-email@gmail.com
SMTP_SENDER_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Logging (optional)
LOG_LEVEL=INFO

# RAG settings (optional — defaults work well)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# MODERATION_ENABLED=true
# MODERATION_MODEL=omni-moderation-latest
# MODERATION_TIMEOUT_SECONDS=8
# MODERATION_FAIL_CLOSED=false
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=100
# RAG_TOP_K=6
# RAG_EMBEDDING_BATCH_SIZE=50
# RAG_EMBEDDING_MAX_RETRIES=4

# Search and planning defaults (optional)
# MAX_FLIGHT_RESULTS=5
# RAW_FLIGHT_CANDIDATES=15
# MAX_HOTEL_RESULTS=5
# DEFAULT_CURRENCY=EUR
# DEFAULT_STAY_NIGHTS=7
